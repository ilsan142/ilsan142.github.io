source "https://rubygems.org"

# GitHub Pages는 원격에서 빌드되므로 로컬은 선택사항입니다.
# 로컬 미리보기:  bundle install  &&  bundle exec jekyll serve

gem "github-pages", group: :jekyll_plugins
gem "jekyll-remote-theme"

group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

# WSL / 일부 리눅스에서 필요
gem "webrick", "~> 1.8"
